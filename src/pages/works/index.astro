---
import Base from '../../layouts/Base.astro';

// ✏️ 在这里添加你的作品，把图片放到 public/images/works/ 目录下
const works = [
  {
    src: "/images/works/photo-1.jpg",
    title: "光与影",
    date: "2026-04",
    desc: "清晨的光线穿过窗帘，落在地板上的那一刻。",
  },
  {
    src: "/images/works/photo-2.jpg",
    title: "城市角落",
    date: "2026-03",
    desc: "城市里被忽视的安静角落。",
  },
  {
    src: "/images/works/photo-3.jpg",
    title: "人物",
    date: "2026-02",
    desc: "街头偶遇的陌生人。",
  },
];
---
<Base title="作品" description="摄影作品集">
  <style>
    .page-header { margin-bottom: 2.5rem; }
    .page-header h1 { margin-bottom: 0.4rem; }
    .page-header p { color: var(--ink-light); font-size: 0.9rem; font-weight: 300; }

    .gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

    .photo-item { }
    .photo-wrap {
      aspect-ratio: 4/3;
      overflow: hidden;
      background: var(--border);
      border-radius: 4px;
      margin-bottom: 0.75rem;
    }
    .photo-wrap img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease;
    }
    .photo-item:hover .photo-wrap img { transform: scale(1.03); }

    /* 占位（图片未放时显示） */
    .photo-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      color: var(--ink-faint);
      font-size: 0.8rem;
      font-weight: 300;
    }

    .photo-title { font-family: var(--serif); font-size: 0.95rem; font-weight: 500; margin-bottom: 0.2rem; }
    .photo-meta { font-size: 0.8rem; color: var(--ink-faint); font-weight: 300; }
    .photo-desc { font-size: 0.85rem; color: var(--ink-light); font-weight: 300; margin-top: 0.25rem; }

    @media (max-width: 560px) { .gallery { grid-template-columns: 1fr; } }
  </style>

  <div class="page-header">
    <h1>作品</h1>
    <p>摄影记录。</p>
  </div>

  <div class="gallery">
    {works.map(work => (
      <div class="photo-item">
        <div class="photo-wrap">
          <!-- 如果图片存在就显示，否则显示占位 -->
          <img src={work.src} alt={work.title} onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div class="photo-placeholder" style="display:none">图片放到 public/images/works/ 目录</div>
        </div>
        <div class="photo-title">{work.title}</div>
        <div class="photo-meta">{work.date}</div>
        <div class="photo-desc">{work.desc}</div>
      </div>
    ))}
  </div>
</Base>