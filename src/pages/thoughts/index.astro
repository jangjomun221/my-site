---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('thoughts'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<Base title="感悟" description="随笔、思考与感悟">
  <style>
    .page-header { margin-bottom: 2.5rem; }
    .page-header h1 { margin-bottom: 0.4rem; }

    .thought-list { list-style: none; }
    .thought-item { padding: 1.5rem 0; border-bottom: 1px solid var(--border); }
    .thought-item:first-child { border-top: 1px solid var(--border); }
    .thought-meta { font-size: 0.8rem; color: var(--ink-faint); margin-bottom: 0.4rem; font-weight: 300; }
    .thought-title { font-family: var(--serif); font-size: 1.15rem; font-weight: 500; }
    .thought-title a { text-decoration: none; color: var(--ink); }
    .thought-title a:hover { color: var(--accent); }
    .thought-desc { margin-top: 0.4rem; font-size: 0.875rem; color: var(--ink-light); font-weight: 300; }
  </style>

  <div class="page-header">
    <h1>感悟</h1>
  </div>

  <ul class="thought-list">
    {items.map(item => (
      <li class="thought-item">
        <div class="thought-meta">{item.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}</div>
        <div class="thought-title"><a href={`/thoughts/${item.id}`}>{item.data.title}</a></div>
        <div class="thought-desc">{item.data.description}</div>
      </li>
    ))}
  </ul>
</Base>