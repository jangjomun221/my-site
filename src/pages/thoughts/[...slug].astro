---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = (await getCollection('thoughts'))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  return items.map((item, i) => ({
    params: { slug: item.id },
    props: {
      item,
      prev: items[i + 1] || null,
      next: items[i - 1] || null,
    },
  }));
}

const { item, prev, next } = Astro.props;
const { Content } = await render(item);
---
<Base title={item.data.title} description={item.data.description}>
  <style>
    .post-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .post-meta { font-size: 0.8rem; color: var(--ink-faint); margin-bottom: 0.75rem; font-weight: 300; }
    .post-header h1 { line-height: 1.3; }
    .back { display: inline-block; font-size: 0.85rem; color: var(--ink-light); text-decoration: none; margin-bottom: 2rem; }
    .back:hover { color: var(--accent); }

    .post-nav {
      display: flex;
      justify-content: space-between;
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      gap: 1rem;
    }
    .post-nav a {
      font-size: 0.85rem;
      color: var(--ink-light);
      text-decoration: none;
      font-weight: 300;
      transition: color 0.15s;
      max-width: 45%;
    }
    .post-nav a:hover { color: var(--accent); }
    .post-nav .nav-next { text-align: right; margin-left: auto; }
  </style>

  <a href="/thoughts" class="back">&larr; 感悟</a>

  <div class="post-header">
    <div class="post-meta">{item.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}</div>
    <h1>{item.data.title}</h1>
  </div>

  <div class="prose">
    <Content />
  </div>

  <nav class="post-nav">
    {prev && <a href={`/thoughts/${prev.id}`}>&larr; {prev.data.title}</a>}
    {next && <a class="nav-next" href={`/thoughts/${next.id}`}>{next.data.title} &rarr;</a>}
  </nav>
</Base>
