---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={post.data.title} description={post.data.description}>
  <style>
    .post-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .post-meta { font-size: 0.8rem; color: var(--ink-faint); margin-bottom: 0.75rem; font-weight: 300; }
    .post-header h1 { line-height: 1.3; }
    .back { display: inline-block; font-size: 0.85rem; color: var(--ink-light); text-decoration: none; margin-bottom: 2rem; }
    .back:hover { color: var(--accent); }
  </style>

  <a href="/blog" class="back">&larr; 博客</a>

  <div class="post-header">
    <div class="post-meta">{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}</div>
    <h1>{post.data.title}</h1>
  </div>

  <div class="prose">
    <Content />
  </div>
</Base>