---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<Base title="博客" description="技术文章与学习笔记">
  <style>
    .page-header { margin-bottom: 2.5rem; }
    .page-header h1 { margin-bottom: 0.4rem; }
    .page-header p { color: var(--ink-light); font-size: 0.9rem; font-weight: 300; }

    .post-list { list-style: none; }
    .post-item {
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .post-item:first-child { border-top: 1px solid var(--border); }
    .post-meta { font-size: 0.8rem; color: var(--ink-faint); margin-bottom: 0.4rem; font-weight: 300; }
    .post-title { font-family: var(--serif); font-size: 1.15rem; font-weight: 500; }
    .post-title a { text-decoration: none; color: var(--ink); }
    .post-title a:hover { color: var(--accent); }
    .post-desc { margin-top: 0.4rem; font-size: 0.875rem; color: var(--ink-light); font-weight: 300; }
  </style>

  <div class="page-header">
    <h1>博客</h1>
  </div>

  <ul class="post-list">
    {posts.map(post => (
      <li class="post-item">
        <div class="post-meta">{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}</div>
        <div class="post-title"><a href={`/blog/${post.id}`}>{post.data.title}</a></div>
        <div class="post-desc">{post.data.description}</div>
      </li>
    ))}
  </ul>
</Base>
