---
import Base from '../layouts/Base.astro';
---
<Base title="首页">
  <style>
    .hero { padding: 2rem 0 3rem; }
    .hero-eyebrow { font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 1rem; font-weight: 400; }
    .hero h1 { font-size: 2.6rem; margin-bottom: 1.25rem; }
    .hero-desc { font-size: 1.05rem; color: var(--ink-light); max-width: 480px; line-height: 1.8; font-weight: 300; }
    .hero-links { display: flex; gap: 0.75rem; margin-top: 2rem; flex-wrap: wrap; }
    .btn {
      display: inline-block;
      padding: 0.5rem 1.2rem;
      border-radius: 4px;
      font-size: 0.875rem;
      text-decoration: none;
      font-weight: 400;
      transition: all 0.15s;
    }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: #a04e2e; color: #fff; }
    .btn-ghost { border: 1px solid var(--border); color: var(--ink-light); }
    .btn-ghost:hover { border-color: var(--ink-light); color: var(--ink); }

    .divider { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

    .section-title {
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 1.25rem;
    }
    .recent-list { list-style: none; }
    .recent-list li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--border);
      gap: 1rem;
    }
    .recent-list li:last-child { border-bottom: none; }
    .recent-list a { text-decoration: none; color: var(--ink); font-weight: 400; font-size: 0.95rem; }
    .recent-list a:hover { color: var(--accent); }
    .recent-list .date { font-size: 0.8rem; color: var(--ink-faint); white-space: nowrap; font-weight: 300; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 1rem; }
    @media (max-width: 560px) { .grid-2 { grid-template-columns: 1fr; } .hero h1 { font-size: 2rem; } }
  </style>

  <section class="hero">
    <p class="hero-eyebrow">你好，我是</p>
    <!-- ✏️ 改成你的名字 -->
    <h1>你的名字</h1>
    <!-- ✏️ 改成你的一句话介绍 -->
    <p class="hero-desc">
      设计师 / 摄影师 / 写作者。<br />
      记录思考，留存影像，分享所学。
    </p>
    <div class="hero-links">
      <a href="/resume" class="btn btn-primary">查看履历</a>
      <a href="/works" class="btn btn-ghost">摄影作品</a>
    </div>
  </section>

  <hr class="divider" />

  <div class="grid-2">
    <div>
      <p class="section-title">最新博客</p>
      <ul class="recent-list">
        <!-- ✏️ 之后可以用 Astro getCollection 动态生成，现在先手写占位 -->
        <li>
          <a href="/blog/first-post">我的第一篇技术文章</a>
          <span class="date">2026-05</span>
        </li>
        <li>
          <a href="/blog">更多 →</a>
          <span class="date"></span>
        </li>
      </ul>
    </div>
    <div>
      <p class="section-title">近期感悟</p>
      <ul class="recent-list">
        <li>
          <a href="/thoughts/first-thought">关于慢下来这件事</a>
          <span class="date">2026-05</span>
        </li>
        <li>
          <a href="/thoughts">更多 →</a>
          <span class="date"></span>
        </li>
      </ul>
    </div>
  </div>
</Base>