---
import Base from '../layouts/Base.astro';
---
<Base title="履历" description="个人履历与经历">
  <style>
    .page-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .page-header h1 { margin-bottom: 0.4rem; }
    .page-header p { color: var(--ink-light); font-size: 0.95rem; }

    .section { margin-bottom: 2.5rem; }
    .section h2 {
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 1rem;
      font-family: var(--sans);
      font-weight: 400;
    }

    .entry { display: grid; grid-template-columns: 1fr auto; gap: 0.25rem 1rem; margin-bottom: 1.5rem; }
    .entry-title { font-weight: 500; font-size: 0.95rem; }
    .entry-org { font-size: 0.875rem; color: var(--ink-light); font-weight: 300; }
    .entry-date { font-size: 0.8rem; color: var(--ink-faint); white-space: nowrap; text-align: right; font-weight: 300; }
    .entry-desc { grid-column: 1 / -1; font-size: 0.875rem; color: var(--ink-light); font-weight: 300; margin-top: 0.2rem; }

    .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tag {
      font-size: 0.8rem;
      padding: 0.2rem 0.65rem;
      border: 1px solid var(--border);
      border-radius: 20px;
      color: var(--ink-light);
      font-weight: 300;
    }

    .contact-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
    .contact-list li { font-size: 0.9rem; font-weight: 300; }
    .contact-list a { color: var(--accent); text-decoration: none; }
  </style>

  <div class="page-header">
    <!-- ✏️ 改成你的信息 -->
    <h1>你的名字</h1>
    <p>设计师 / 摄影师 / 写作者 · 坐标：上海</p>
  </div>

  <!-- ✏️ 教育经历 -->
  <div class="section">
    <h2>教育</h2>
    <div class="entry">
      <span class="entry-title">某某大学</span>
      <span class="entry-date">2018 – 2022</span>
      <span class="entry-org">设计学院 · 视觉传达设计</span>
    </div>
  </div>

  <!-- ✏️ 工作经历 -->
  <div class="section">
    <h2>经历</h2>
    <div class="entry">
      <span class="entry-title">高级设计师</span>
      <span class="entry-date">2023 – 至今</span>
      <span class="entry-org">某某公司</span>
      <span class="entry-desc">负责产品 UI/UX 设计，参与品牌视觉体系建设。</span>
    </div>
    <div class="entry">
      <span class="entry-title">设计实习生</span>
      <span class="entry-date">2022</span>
      <span class="entry-org">另一家公司</span>
      <span class="entry-desc">参与移动端界面设计，协助完成品牌物料制作。</span>
    </div>
  </div>

  <!-- ✏️ 技能 -->
  <div class="section">
    <h2>技能</h2>
    <div class="tags">
      <span class="tag">Figma</span>
      <span class="tag">摄影</span>
      <span class="tag">后期修图</span>
      <span class="tag">排版设计</span>
      <span class="tag">HTML / CSS</span>
      <span class="tag">写作</span>
    </div>
  </div>

  <!-- ✏️ 联系方式 -->
  <div class="section">
    <h2>联系</h2>
    <ul class="contact-list">
      <li>邮件：<a href="mailto:you@example.com">you@example.com</a></li>
      <li>GitHub：<a href="https://github.com/yourusername" target="_blank">github.com/yourusername</a></li>
    </ul>
  </div>
</Base>