---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "个人网站" } = Astro.props;
const pathname = Astro.url.pathname;
const nav = [
  { href: "/", label: "首页" },
  { href: "/resume", label: "履历" },
  { href: "/blog", label: "博客" },
  { href: "/thoughts", label: "感悟" },
  { href: "/works", label: "作品" },
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;700&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #faf9f7;
      --ink: #1a1a18;
      --ink-light: #6b6b68;
      --ink-faint: #c8c7c2;
      --accent: #b85c38;
      --border: #e8e7e2;
      --serif: 'Noto Serif SC', serif;
      --sans: 'Noto Sans SC', sans-serif;
      --max: 720px;
    }

    html { background: var(--bg); color: var(--ink); font-family: var(--sans); font-size: 16px; line-height: 1.7; }
    body { min-height: 100vh; display: flex; flex-direction: column; }

    /* Header */
    header {
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      position: sticky; top: 0;
      background: rgba(250,249,247,0.92);
      backdrop-filter: blur(8px);
      z-index: 10;
    }
    .header-inner {
      max-width: var(--max);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .site-name {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
      text-decoration: none;
      letter-spacing: 0.02em;
    }
    nav { display: flex; gap: 0.25rem; }
    nav a {
      font-size: 0.85rem;
      color: var(--ink-light);
      text-decoration: none;
      padding: 0.3rem 0.6rem;
      border-radius: 4px;
      transition: color 0.15s, background 0.15s;
      font-weight: 300;
    }
    nav a:hover { color: var(--ink); background: var(--border); }
    nav a.active { color: var(--accent); font-weight: 500; }

    /* Main */
    main {
      flex: 1;
      max-width: var(--max);
      margin: 0 auto;
      width: 100%;
      padding: 3rem 2rem;
    }

    /* Footer */
    footer {
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 1.5rem;
      font-size: 0.8rem;
      color: var(--ink-faint);
      font-weight: 300;
    }

    /* Typography */
    h1 { font-family: var(--serif); font-size: 2rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.5rem; }
    h2 { font-family: var(--serif); font-size: 1.35rem; font-weight: 500; margin: 2rem 0 0.75rem; }
    h3 { font-size: 1rem; font-weight: 500; margin: 1.5rem 0 0.5rem; }
    p { margin-bottom: 1rem; font-weight: 300; color: #2e2e2b; }
    a { color: var(--accent); }

    /* Prose */
    .prose h2 { border-bottom: 1px solid var(--border); padding-bottom: 0.4rem; }
    .prose ul { padding-left: 1.5rem; margin-bottom: 1rem; }
    .prose ul li { margin-bottom: 0.3rem; font-weight: 300; color: #2e2e2b; }
    .prose blockquote {
      border-left: 3px solid var(--accent);
      padding: 0.5rem 0 0.5rem 1.2rem;
      margin: 1.5rem 0;
      color: var(--ink-light);
      font-style: italic;
      font-family: var(--serif);
    }
    .prose img { width: 100%; border-radius: 4px; margin: 1.5rem 0; }
    .prose code { background: var(--border); padding: 0.15em 0.4em; border-radius: 3px; font-size: 0.875em; }
    .prose pre { background: #1a1a18; color: #e8e7e2; padding: 1.25rem; border-radius: 6px; overflow-x: auto; margin: 1.5rem 0; }
    .prose pre code { background: none; padding: 0; font-size: 0.875rem; }

    @media (max-width: 600px) {
      main { padding: 2rem 1.25rem; }
      h1 { font-size: 1.6rem; }
      nav a { padding: 0.3rem 0.4rem; font-size: 0.8rem; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="site-name">我的站点</a>
      <nav>
        {nav.map(item => (
          <a href={item.href} class={pathname === item.href || (item.href !== "/" && pathname.startsWith(item.href)) ? "active" : ""}>
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>© 2026 · 用 Astro 构建</footer>
</body>
</html>